# Server
PORT=3001
NODE_ENV=development

# Database (XAMPP MySQL)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=dmm_scheduly

# Authentication - generate a strong random string
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=24h

# Facebook App — get from https://developers.facebook.com
FB_APP_ID=
FB_APP_SECRET=
FB_REDIRECT_URI=http://localhost:3001/api/social/auth/facebook/callback

# Encryption key — 32 bytes hex (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=change-me-to-a-64-char-hex-string

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=104857600

# Instagram requires public URLs for media uploads
# Set this to your server's public URL when publishing to Instagram
IG_PUBLIC_BASE_URL=

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173
